{
  "name": "odin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal proxy server bridging Claude Code CLI to Google Antigravity Cloud Code API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test 'tests/**/*.test.js'",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "check": "eslint src/ tests/ && prettier --check src/ tests/"
  },
  "author": "Chason Tang",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.8.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  }
}