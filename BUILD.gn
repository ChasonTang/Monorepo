# Root BUILD.gn file for the Monorepo project

group("default") {
  deps = [
    "//boringssl:ssl",
    "//c-ares:cares",
    "//xquic",
  ]

  # ipsw parses dyld_shared_cache via <mach-o/loader.h>; Darwin-only by
  # construction.
  if (target_os == "mac") {
    deps += [ "//ipsw:ipsw" ]
  }
}

group("all") {
  deps = [ ":default" ]
}
